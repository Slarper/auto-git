# AI Provider (default: openrouter)
AI_PROVIDER="openrouter"
# AI Model (default: deepseek/deepseek-v4-flash)
AI_MODEL="deepseek/deepseek-v4-flash"
# API key for the AI provider (REQUIRED)
AI_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# GitHub Personal Access Token with repo scope (REQUIRED for push)
GITHUB_PAT="github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Git remote name (default: origin)
GIT_REMOTE="origin"
